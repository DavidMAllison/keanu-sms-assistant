<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.keanu.sms-assistant</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/Shared/sms-assistant/start.sh</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/Shared/sms-assistant</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/Shared/sms-assistant/keanu.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/Shared/sms-assistant/keanu.log</string>
</dict>
</plist>
